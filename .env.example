# =============================================================================
# PING Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked (required) must be set for the app to start.
# Variables marked (optional) enable additional features.

# ---------- Convex ----------
NEXT_PUBLIC_CONVEX_URL=               # (required) Your Convex deployment URL
CONVEX_DEPLOY_KEY=                    # (required for deploy) Convex deploy key

# ---------- WorkOS Authentication ----------
WORKOS_API_KEY=                       # (required) WorkOS API key (sk_test_... or sk_live_...)
WORKOS_CLIENT_ID=                     # (required) WorkOS client ID (client_...)
WORKOS_COOKIE_PASSWORD=               # (required) Min 32 chars, random string for cookie encryption
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback  # (required) OAuth callback URL

# ---------- OpenAI (powers AI features) ----------
OPENAI_API_KEY=                       # (required for AI) OpenAI API key for summaries, triage, alerts

# ---------- Graphiti Knowledge Engine ----------
GRAPHITI_API_URL=http://localhost:8000  # (optional) Knowledge engine API URL

# ---------- PostHog Analytics ----------
NEXT_PUBLIC_POSTHOG_KEY=              # (optional) PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com  # (optional) PostHog ingest host

# ---------- Sentry Error Tracking ----------
NEXT_PUBLIC_SENTRY_DSN=               # (optional) Sentry DSN for error tracking

# ---------- Linear Feedback → Issues ----------
LINEAR_API_KEY=                       # (optional) Linear API key for auto-creating feedback issues
LINEAR_TEAM_ID=                       # (optional) Linear team ID to file feedback into
LINEAR_FEEDBACK_LABEL_ID=             # (optional) Linear label ID to tag feedback issues

# ---------- Webhook Secrets ----------
LINEAR_WEBHOOK_SECRET=                # (optional) HMAC secret for Linear webhook verification
GITHUB_WEBHOOK_SECRET=                # (optional) HMAC secret for GitHub webhook verification

# ---------- Deployment ----------
VERCEL_DEPLOY_HOOK=                   # (CI only) Vercel deploy hook URL
FLY_API_TOKEN=                        # (CI only) Fly.io API token for knowledge engine deploy

# ---------- Workspace Routing (production) ----------
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000  # Root domain (production: ping.app)
NEXT_PUBLIC_APP_DOMAIN=localhost:3000   # App domain shown in UI
WORKOS_COOKIE_DOMAIN=.localhost         # Cookie domain (production: .ping.app)
