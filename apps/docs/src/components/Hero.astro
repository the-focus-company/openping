---
const base = import.meta.env.BASE_URL;
---

<section class="ping-hero">
  <div class="ping-hero-inner">
    <div class="ping-hero-badge">Documentation</div>
    <h1 class="ping-hero-title">
      Build with <span class="ping-hero-accent">PING</span>
    </h1>
    <p class="ping-hero-subtitle">
      The AI-native workspace for team communication. Explore guides, API
      references, and everything you need to get started.
    </p>
    <div class="ping-hero-actions">
      <a href={`${base}getting-started/introduction/`} class="ping-btn ping-btn-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href={`${base}api/overview/`} class="ping-btn ping-btn-secondary">
        API Reference
      </a>
    </div>
  </div>
</section>

<style>
  .ping-hero {
    width: 100%;
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--ping-border);
  }

  .ping-hero-inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  .ping-hero-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ping-accent);
    background: var(--sl-color-accent-low);
    border: 1px solid var(--ping-border);
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .ping-hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--ping-text);
    margin: 0 0 1rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .ping-hero-accent {
    background: linear-gradient(135deg, #5e6ad2, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ping-hero-subtitle {
    font-size: 1.125rem;
    color: var(--ping-text-muted);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .ping-hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ping-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .ping-btn-primary {
    background: var(--ping-accent);
    color: #fff;
    box-shadow: 0 1px 2px rgba(94, 106, 210, 0.3);
  }

  .ping-btn-primary:hover {
    background: #4f5bc4;
    box-shadow: 0 2px 8px rgba(94, 106, 210, 0.4);
  }

  .ping-btn-secondary {
    background: transparent;
    color: var(--ping-text);
    border: 1px solid var(--ping-border);
  }

  .ping-btn-secondary:hover {
    background: var(--ping-surface-raised);
    border-color: var(--ping-accent);
    color: var(--ping-accent);
  }
</style>
