---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="mint-card">
  <div class="mint-card-icon">{icon}</div>
  <div class="mint-card-body">
    <h3 class="mint-card-title">
      {title}
      <svg class="mint-card-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none">
        <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </h3>
    <p class="mint-card-desc">{description}</p>
  </div>
</a>

<style>
  .mint-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: var(--ping-card-shadow);
  }

  .mint-card:hover {
    border-color: var(--ping-accent);
    box-shadow: var(--ping-card-shadow-hover);
    transform: translateY(-1px);
  }

  .mint-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.25rem;
    background: var(--sl-color-accent-low);
    border-radius: 0.5rem;
    border: 1px solid var(--ping-border);
  }

  .mint-card-body {
    min-width: 0;
  }

  .mint-card-title {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ping-text);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .mint-card-arrow {
    flex-shrink: 0;
    color: var(--ping-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.15s ease;
  }

  .mint-card:hover .mint-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--ping-accent);
  }

  .mint-card-desc {
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
