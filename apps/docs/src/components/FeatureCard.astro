---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="fc">
  <span class="fc-accent" aria-hidden="true"></span>
  <span class="fc-glow" aria-hidden="true"></span>
  <span class="fc-inner">
    <span class="fc-icon">
      <span class="fc-icon-emoji">{icon}</span>
    </span>
    <span class="fc-body">
      <span class="fc-title">{title}</span>
      <span class="fc-desc">{description}</span>
    </span>
    <svg class="fc-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
  /* ── Card shell ── */
  .fc {
    --_accent: var(--ping-accent, #5e6ad2);
    position: relative;
    display: block;
    border-radius: 1rem;
    text-decoration: none;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    outline: none;
  }

  .fc:hover {
    transform: translateY(-2px);
  }

  .fc:focus-visible {
    box-shadow: 0 0 0 2px var(--_accent);
  }

  /* ── Left accent bar ── */
  .fc-accent {
    position: absolute;
    left: 0;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: var(--_accent);
    opacity: 0;
    transform: scaleY(0.4);
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fc:hover .fc-accent {
    opacity: 1;
    transform: scaleY(1);
  }

  /* ── Hover glow wash ── */
  .fc-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      rgba(94, 106, 210, 0.06) 0%,
      rgba(129, 140, 248, 0.03) 50%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .fc:hover .fc-glow {
    opacity: 1;
  }

  /* ── Inner content layer ── */
  .fc-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    border-radius: inherit;
    border: 1px solid var(--ping-border);
    background: var(--ping-surface);
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .fc:hover .fc-inner {
    border-color: rgba(94, 106, 210, 0.25);
  }

  /* ── Icon ── */
  .fc-icon {
    flex-shrink: 0;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    background: var(--sl-color-accent-low);
    border: 1px solid var(--ping-border);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .fc:hover .fc-icon {
    border-color: rgba(94, 106, 210, 0.2);
    box-shadow: 0 0 16px rgba(94, 106, 210, 0.12);
  }

  .fc-icon-emoji {
    font-size: 1.25rem;
    line-height: 1;
    filter: saturate(0.9);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .fc:hover .fc-icon-emoji {
    transform: scale(1.08);
  }

  /* ── Text ── */
  .fc-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .fc-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ping-text);
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .fc:hover .fc-title {
    color: var(--_accent);
  }

  .fc-desc {
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
    line-height: 1.55;
  }

  /* ── Arrow ── */
  .fc-arrow {
    flex-shrink: 0;
    color: var(--ping-text-muted);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), color 0.2s ease;
  }

  .fc:hover .fc-arrow {
    opacity: 0.7;
    transform: translateX(0);
    color: var(--_accent);
  }

  /* ── Dark mode ── */
  :root[data-theme="dark"] .fc-inner {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root[data-theme="dark"] .fc:hover .fc-inner {
    background: rgba(255, 255, 255, 0.035);
    border-color: rgba(94, 106, 210, 0.3);
  }

  :root[data-theme="dark"] .fc-icon {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root[data-theme="dark"] .fc:hover .fc-icon {
    background: rgba(94, 106, 210, 0.08);
    border-color: rgba(94, 106, 210, 0.2);
    box-shadow: 0 0 20px rgba(94, 106, 210, 0.1);
  }

  :root[data-theme="dark"] .fc:hover .fc-title {
    color: #c7caff;
  }

  :root[data-theme="dark"] .fc-glow {
    background: linear-gradient(
      135deg,
      rgba(94, 106, 210, 0.08) 0%,
      rgba(129, 140, 248, 0.04) 50%,
      transparent 100%
    );
  }

  :root[data-theme="dark"] .fc-accent {
    background: linear-gradient(180deg, #818cf8, #5e6ad2);
  }
</style>
