---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="ping-card">
  <div class="ping-card-gradient"></div>
  <div class="ping-card-content">
    <div class="ping-card-icon">{icon}</div>
    <div class="ping-card-body">
      <h3 class="ping-card-title">
        {title}
        <svg class="ping-card-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </h3>
      <p class="ping-card-desc">{description}</p>
    </div>
  </div>
</a>

<style>
  .ping-card {
    position: relative;
    display: block;
    overflow: hidden;
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: var(--ping-card-shadow);
    min-height: 4.5rem;
  }

  .ping-card:hover {
    border-color: rgba(94, 106, 210, 0.3);
    box-shadow: var(--ping-card-shadow-hover);
    transform: translateY(-1px);
  }

  /* Gradient overlay on hover — matches landing page GlowCard */
  .ping-card-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(94, 106, 210, 0.06),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .ping-card:hover .ping-card-gradient {
    opacity: 1;
  }

  .ping-card-content {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: var(--ping-surface);
  }

  .ping-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.25rem;
    background: var(--sl-color-accent-low);
    border-radius: 0.625rem;
    border: 1px solid var(--ping-border);
    transition: all 0.2s ease;
  }

  .ping-card:hover .ping-card-icon {
    border-color: rgba(94, 106, 210, 0.2);
  }

  .ping-card-body {
    min-width: 0;
  }

  .ping-card-title {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ping-text);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .ping-card-arrow {
    flex-shrink: 0;
    color: var(--ping-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.15s ease;
  }

  .ping-card:hover .ping-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--ping-accent);
  }

  .ping-card-desc {
    font-size: 0.8125rem;
    color: var(--ping-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Dark mode — matches web app card pattern */
  :root[data-theme="dark"] .ping-card {
    border-color: rgba(255, 255, 255, 0.06);
  }

  :root[data-theme="dark"] .ping-card:hover {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :root[data-theme="dark"] .ping-card-content {
    background: var(--ping-surface-raised);
  }

  :root[data-theme="dark"] .ping-card-icon {
    border-color: rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.04);
  }

  :root[data-theme="dark"] .ping-card:hover .ping-card-icon {
    background: rgba(255, 255, 255, 0.08);
  }
</style>
