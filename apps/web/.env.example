# WorkOS AuthKit
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=a-32-character-or-longer-random-string
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Root domain for subdomain workspace routing (production only)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Domain shown in UI for workspace URL preview
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
# Cookie domain for cross-subdomain auth (production: .ping.app)
WORKOS_COOKIE_DOMAIN=.localhost
