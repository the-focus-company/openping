---
import PitchDeck from "../components/PitchDeck";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OpenPing - Investor Overview 2026</title>
    <meta name="description" content="OpenPing removes the coordination layer that keeps service firms from scaling. Investor overview 2026." />
    <meta property="og:title" content="OpenPing - Investor Overview 2026" />
    <meta property="og:description" content="OpenPing removes the coordination layer that keeps service firms from scaling. Investor overview 2026." />
    <meta property="og:image" content="/og.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="OpenPing - Investor Overview 2026" />
    <meta name="twitter:description" content="OpenPing removes the coordination layer that keeps service firms from scaling. Investor overview 2026." />
    <meta name="twitter:image" content="/og.png" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; font-family: 'Outfit', system-ui, -apple-system, sans-serif; }
      ::-webkit-scrollbar { display: none; }

      /* ── Light mode: full invert approach with hue correction ── */
      html[data-theme="light"] body {
        background: #fafafa !important;
      }
      html[data-theme="light"] #deck-bg {
        background: #fafafa !important;
      }
      html[data-theme="light"] #deck-bg > div {
        opacity: 0.3;
      }
      /* Invert all text and bg colors */
      html[data-theme="light"] .text-white { color: #0a0a0a !important; }
      html[data-theme="light"] .text-neutral-300 { color: #525252 !important; }
      html[data-theme="light"] .text-neutral-400 { color: #525252 !important; }
      html[data-theme="light"] .text-neutral-500 { color: #737373 !important; }
      html[data-theme="light"] .text-neutral-600 { color: #737373 !important; }
      html[data-theme="light"] .text-neutral-700 { color: #a3a3a3 !important; }
      html[data-theme="light"] .text-neutral-800 { color: #d4d4d4 !important; }

      html[data-theme="light"] .bg-black { background-color: #fafafa !important; }
      html[data-theme="light"] .bg-neutral-900 { background-color: #f5f5f5 !important; }
      html[data-theme="light"] .bg-neutral-950 { background-color: #ffffff !important; }

      /* Borders */
      html[data-theme="light"] .border-neutral-700 { border-color: #d4d4d4 !important; }
      html[data-theme="light"] .border-neutral-800 { border-color: #e5e5e5 !important; }
      html[data-theme="light"] .border-neutral-900 { border-color: #f5f5f5 !important; }

      /* Cards and backgrounds with opacity - use attribute selectors */
      html[data-theme="light"] [class*="bg-neutral-950"] { background-color: #ffffff !important; }
      html[data-theme="light"] [class*="bg-neutral-900"] { background-color: #f5f5f5 !important; }
      html[data-theme="light"] [class*="border-neutral-800"] { border-color: #e5e5e5 !important; }
      html[data-theme="light"] [class*="border-neutral-900"] { border-color: #f5f5f5 !important; }
      html[data-theme="light"] [class*="border-neutral-700"] { border-color: #d4d4d4 !important; }

      /* Accent backgrounds */
      html[data-theme="light"] [class*="bg-indigo-950"] { background-color: rgba(79,70,229,0.06) !important; }
      html[data-theme="light"] [class*="bg-violet-950"] { background-color: rgba(139,92,246,0.06) !important; }
      html[data-theme="light"] [class*="bg-purple-950"] { background-color: rgba(168,85,247,0.06) !important; }
      html[data-theme="light"] [class*="bg-emerald-950"] { background-color: rgba(16,185,129,0.06) !important; }
      html[data-theme="light"] [class*="bg-emerald-900"] { background-color: rgba(16,185,129,0.06) !important; }
      html[data-theme="light"] [class*="bg-amber-950"] { background-color: rgba(245,158,11,0.06) !important; }
      html[data-theme="light"] [class*="bg-rose-950"] { background-color: rgba(225,29,72,0.06) !important; }

      /* Callout borders */
      html[data-theme="light"] [class*="border-amber-900"] { border-color: rgba(245,158,11,0.2) !important; }
      html[data-theme="light"] [class*="border-rose-900"] { border-color: rgba(225,29,72,0.2) !important; }
      html[data-theme="light"] [class*="border-indigo-900"] { border-color: rgba(79,70,229,0.2) !important; }
      html[data-theme="light"] [class*="border-emerald-700"] { border-color: rgba(16,185,129,0.2) !important; }
      html[data-theme="light"] [class*="border-amber-700"] { border-color: rgba(245,158,11,0.2) !important; }
      html[data-theme="light"] [class*="border-indigo-700"] { border-color: rgba(79,70,229,0.2) !important; }
      html[data-theme="light"] [class*="border-indigo-800"] { border-color: rgba(79,70,229,0.15) !important; }
      html[data-theme="light"] [class*="border-violet-800"] { border-color: rgba(139,92,246,0.15) !important; }
      html[data-theme="light"] [class*="border-purple-800"] { border-color: rgba(168,85,247,0.15) !important; }
      html[data-theme="light"] [class*="border-emerald-800"] { border-color: rgba(16,185,129,0.15) !important; }

      /* Accent colors - darker for light bg */
      html[data-theme="light"] .text-indigo-400 { color: #4338ca !important; }
      html[data-theme="light"] .text-indigo-300 { color: #4f46e5 !important; }
      html[data-theme="light"] .text-violet-400 { color: #6d28d9 !important; }
      html[data-theme="light"] .text-emerald-400 { color: #059669 !important; }
      html[data-theme="light"] .text-emerald-300 { color: #10b981 !important; }
      html[data-theme="light"] .text-emerald-600 { color: #059669 !important; }
      html[data-theme="light"] .text-amber-400 { color: #d97706 !important; }
      html[data-theme="light"] .text-amber-500 { color: #b45309 !important; }
      html[data-theme="light"] .text-rose-400 { color: #e11d48 !important; }
      html[data-theme="light"] .text-sky-400 { color: #0284c7 !important; }
      html[data-theme="light"] .text-orange-400 { color: #ea580c !important; }
      html[data-theme="light"] .text-red-400 { color: #dc2626 !important; }

      /* Gradient text */
      html[data-theme="light"] .from-indigo-400 { --tw-gradient-from: #4338ca !important; }
      html[data-theme="light"] .via-violet-400 { --tw-gradient-via: #6d28d9 !important; }
      html[data-theme="light"] .to-purple-400 { --tw-gradient-to: #7e22ce !important; }
      html[data-theme="light"] .from-emerald-400 { --tw-gradient-from: #059669 !important; }
      html[data-theme="light"] .to-sky-400 { --tw-gradient-to: #0284c7 !important; }

      /* CTA button */
      html[data-theme="light"] a.bg-white {
        background-color: #0a0a0a !important;
        color: #ffffff !important;
      }
      html[data-theme="light"] a.bg-white:hover {
        background-color: #262626 !important;
      }

      /* Nav dots */
      html[data-theme="light"] .bg-neutral-700 { background-color: #d4d4d4 !important; }
      html[data-theme="light"] nav button.bg-white { background-color: #0a0a0a !important; }

      /* Radial bg elements - reduce opacity */
      html[data-theme="light"] [style*="radial-gradient"] { opacity: 0.3; }

      /* Ring */
      html[data-theme="light"] [class*="ring-indigo-600"] { --tw-ring-color: rgba(79,70,229,0.15) !important; }
      html[data-theme="light"] [class*="ring-amber-600"] { --tw-ring-color: rgba(245,158,11,0.15) !important; }

      /* Logo + SVG diagrams: invert in light mode */
      html[data-theme="light"] .deck-logo { filter: invert(1) !important; }
      html[data-theme="light"] .deck-svg-dark { filter: invert(1) hue-rotate(180deg) !important; }

      /* Semi-transparent cards/tables so neural bg peeks through */
      .bg-neutral-950 { background-color: rgba(10,10,10,0.85) !important; }
      [class*="bg-neutral-950/80"] { background-color: rgba(10,10,10,0.7) !important; }
      html[data-theme="light"] .bg-neutral-950 { background-color: rgba(255,255,255,0.85) !important; }
      html[data-theme="light"] [class*="bg-neutral-950/80"] { background-color: rgba(255,255,255,0.7) !important; }
    </style>
  </head>
  <body>
    <PitchDeck client:only="react" />
  </body>
</html>
