{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/create-linear-issue.sh",
            "statusMessage": "Creating Linear issue..."
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/update-linear-issue.sh",
            "statusMessage": "Updating Linear issue..."
          }
        ]
      }
    ]
  }
}
